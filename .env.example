# Local development defaults to SQLite if DATABASE_URL is omitted.
# For Postgres, use a URL such as:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/customer_support_ai

DATABASE_URL=sqlite:///./customer_support_ai.db
MAILBOX_PROVIDER=fake

MAILSLURP_API_KEY=
MAILSLURP_INBOX_ID=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_PROVIDER=fake

AUTO_SEND_MIN_ROUTING_CONFIDENCE=0.75
AUTO_SEND_MIN_REPLY_CONFIDENCE=0.75

